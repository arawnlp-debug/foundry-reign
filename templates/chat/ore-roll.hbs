<div class="reign-chat-card">
    <header class="reign-roll-title">
        <i class="fas fa-dice-d10"></i> Rolling {{label}}
    </header>

    {{#if (gt multiActions 1)}}
        <div class="reign-banner reign-banner-warning">
            ATTEMPTING {{multiActions}} ACTIONS<br>
            <small>(Requires {{multiActions}} matched sets)</small>
        </div>
    {{/if}}

    {{#if (gt calledShot 0)}}
        <div class="reign-banner reign-banner-info">
            <i class="fas fa-crosshairs"></i> CALLED SHOT: Height {{calledShot}}
        </div>
    {{/if}}

    <details class="reign-pool-breakdown">
        <summary>
            Pool: {{totalPool}}d10 {{#if wasCapped}}<span class="reign-text-danger">(Capped)</span>{{/if}}
        </summary>
        {{#if poolBreakdown.length}}
            <ul>
                {{#each poolBreakdown as |b|}}
                    <li><strong>{{b.label}}:</strong> <span class="{{#if b.isPenalty}}reign-text-critical{{else}}reign-text-success{{/if}}">{{b.value}}</span></li>
                {{/each}}
            </ul>
        {{/if}}
    </details>

    <div class="sets-result">
        <div class="reign-section-title">Matched Sets</div>
        
        {{#if sets.length}}
            <div class="reign-flex-col-gap8 reign-mb-medium">
                {{#each sets as |set|}}
                    <div class="ore-set {{#if set.isSuccess}}reign-set-success{{else}}reign-set-fail{{/if}}">
                        
                        <div class="dice-tray wrap">
                            {{#each set.dice as |die|}}
                                <div class="reign-die {{die.cssClass}}" title="{{#if (eq die.cssClass 'matched')}}Matched Die{{else}}Waste Die{{/if}}">{{die.value}}</div>
                            {{/each}}
                        </div>
                        
                        <div class="set-details reign-mt-small">
                            {{#if set.location}}
                               <i class="fas fa-bullseye reign-text-success"></i> HIT: <strong>{{set.location}}</strong>
                            {{else if set.isSuccess}}
                               <i class="fas fa-check-circle reign-text-success"></i> <strong class="reign-text-success">Success</strong>
                            {{/if}}

                            {{#unless set.isSuccess}}
                               <div class="reign-text-danger reign-text-bold reign-mt-small"><i class="fas fa-times-circle"></i> FAILED: {{set.failReason}}</div>
                            {{/unless}}
                        </div>

                        {{!-- Gobble UI Block --}}
                        {{#if ../isDefense}}
                            <div class="reign-gobble-gen">
                                <div><strong><i class="fas fa-shield-alt"></i> Generates {{set.width}} Gobble Dice of Height {{set.height}}</strong></div>
                                <div class="reign-gobble-gen-defense">
                                    Defense Type: <strong>{{../defenseTypeLabel}}</strong><br>
                                    {{#if (eq ../defenseType "dodge")}}
                                        <span class="reign-text-danger">(Can only protect yourself)</span>
                                    {{else}}
                                        <span class="reign-text-success">(Can protect yourself or allies)</span>
                                    {{/if}}
                                </div>
                            </div>
                        {{/if}}

                        {{!-- Damage Tags Block --}}
                        {{#if set.dmg}}
                            <div class="reign-dmg-tags">
                                <div><strong>Damage:</strong> {{set.dmg.formula}}</div>
                                <div class="dice-tray wrap">
                                    {{#if set.dmg.ap}}<span class="reign-tag ap-tag">AP {{set.dmg.ap}}</span>{{/if}}
                                    {{#if set.dmg.slow}}<span class="reign-tag">SLOW {{set.dmg.slow}}</span>{{/if}}
                                    {{#if set.dmg.twoHanded}}<span class="reign-tag">2H</span>{{/if}}
                                    {{#if set.dmg.massive}}<span class="reign-tag massive-tag">MASSIVE</span>{{/if}}
                                    {{#if set.dmg.area}}<span class="reign-tag area-tag">AREA {{set.dmg.area}}d</span>{{/if}}
                                </div>
                            </div>
                        {{/if}}

                        {{!-- Healing Block --}}
                        {{#if set.heal}}
                            <div class="reign-heal-tags">
                                <span><strong>Healing:</strong> {{set.heal.formula}}</span>
                            </div>
                        {{/if}}

                        {{!-- Ch7 Maneuver Outcome Block --}}
                        {{#if set.maneuverOutcome}}
                            <div class="reign-maneuver-outcome" style="margin-top: 6px; padding: 6px 8px; border-left: 3px solid {{#if set.maneuverOutcome.isTier1}}var(--reign-blue){{else}}var(--reign-burnt-orange){{/if}}; background: rgba(0,0,0,0.04); border-radius: 0 3px 3px 0; font-size: 0.9em;">
                                <div style="font-weight: bold; margin-bottom: 3px;">
                                    <i class="fas fa-{{#if set.maneuverOutcome.isTier1}}bolt{{else}}scroll{{/if}}"></i>
                                    {{localize set.maneuverOutcome.maneuverLabel}} — {{set.maneuverOutcome.tierLabel}} Success
                                </div>
                                {{#if set.maneuverOutcome.description}}
                                    <div>{{localize set.maneuverOutcome.description}}</div>
                                {{/if}}
                                {{#if set.maneuverOutcome.requiresKill}}
                                    <div class="reign-text-danger reign-text-small" style="margin-top: 3px;">
                                        <i class="fas fa-skull"></i> Must kill the target to trigger this effect.
                                    </div>
                                {{/if}}
                                {{#if set.maneuverOutcome.bonusShock}}
                                    <div class="reign-text-small" style="margin-top: 3px;">
                                        <strong>Bonus Damage:</strong>
                                        {{#if set.maneuverOutcome.bonusKilling}}+{{set.maneuverOutcome.bonusShock}} Shock, +{{set.maneuverOutcome.bonusKilling}} Killing{{else}}+{{set.maneuverOutcome.bonusShock}} Shock{{/if}}
                                    </div>
                                {{/if}}
                                {{#if set.maneuverOutcome.convertKillingToShock}}
                                    <div class="reign-text-small" style="margin-top: 3px; color: var(--reign-blue);">
                                        <i class="fas fa-exchange-alt"></i> All Killing damage converted to Shock.
                                        {{#if set.maneuverOutcome.discardOverflow}} Overflow Shock discarded (non-lethal).{{/if}}
                                    </div>
                                {{/if}}
                                {{#if set.maneuverOutcome.isTier2}}
                                    <details style="margin-top: 4px;">
                                        <summary class="reign-text-muted reign-text-small" style="cursor: pointer;">
                                            <i class="fas fa-book"></i> {{localize 'REIGN.ManeuverTier2Notice'}}
                                        </summary>
                                        <div class="reign-text-small reign-text-muted" style="margin-top: 4px; padding: 4px; background: rgba(0,0,0,0.03);">
                                            {{localize set.maneuverOutcome.rulesText}}
                                        </div>
                                    </details>
                                {{/if}}
                            </div>
                        {{/if}}

                        <div class="reign-action-buttons">
                            {{#if set.initBtn}}
                                <button class="reign-btn-small reign-btn-init set-init-btn" data-width="{{set.width}}" data-height="{{set.height}}" title="Use this set's speed for Combat Initiative">
                                    <i class="fas fa-bolt"></i>
                                </button>
                            {{/if}}

                            {{!-- P1 RAW FIX: Button to select the active Gobble Set --}}
                            {{#if ../needsGobbleSelection}}
                                <button class="reign-btn-small reign-btn-gobble select-gobble-set-btn" data-width="{{set.width}}" data-height="{{set.height}}" title="Select this set as your Gobble Dice">
                                    <i class="fas fa-hand-pointer"></i>
                                </button>
                            {{/if}}

                            {{#unless ../isDefense}}
                                <button class="reign-btn-small reign-btn-gobble gobble-dmg-btn" data-height="{{set.height}}" title="Gobble 1 Die (Use Dodge or Parry)">
                                    <i class="fas fa-shield-alt"></i>
                                </button>
                            {{/unless}}

                            {{#if set.dmg}}
                                <button class="reign-btn-small reign-btn-damage apply-dmg-btn" data-width="{{set.width}}" data-height="{{set.height}}" data-dmg-string="{{set.dmg.formula}}" data-ap="{{set.dmg.ap}}" data-massive="{{set.dmg.massive}}" data-area-dice="{{set.dmg.area}}" title="Apply Primary Damage" {{#unless set.isSuccess}}disabled{{/unless}}>
                                    <i class="fas fa-hand-fist"></i>
                                </button>
                            {{/if}}

                            {{#if set.heal}}
                                <button class="reign-btn-small reign-btn-heal apply-heal-btn" data-width="{{set.width}}" data-height="{{set.height}}" data-heal-string="{{set.heal.formula}}" title="Apply Magical Healing" {{#unless set.isSuccess}}disabled{{/unless}}>
                                    <i class="fas fa-hand-holding-medical"></i>
                                </button>
                            {{/if}}

                            {{#if ../isFirstAid}}
                                <button class="reign-btn-small reign-btn-first-aid apply-first-aid-btn" data-width="{{set.width}}" title="Apply First Aid (Convert Killing to Shock)" {{#unless set.isSuccess}}disabled{{/unless}}>
                                    <i class="fas fa-notes-medical"></i>
                                </button>
                            {{/if}}

                            {{#if set.companyDmg}}
                                <button class="reign-btn-small reign-btn-company apply-company-dmg-btn" data-width="{{set.companyDmg.width}}" data-quality="{{set.companyDmg.quality}}" title="Apply Company Damage" {{#unless set.isSuccess}}disabled{{/unless}}>
                                    <i class="fas fa-chess-rook"></i>
                                </button>
                            {{/if}}

                            {{#if ../hasEffects}}
                                <button class="reign-btn-small reign-btn-condition apply-condition-btn" data-item-uuid="{{../itemUuid}}" title="Apply Condition to Targets" {{#unless set.isSuccess}}disabled{{/unless}}>
                                    <i class="fas fa-bolt"></i>
                                </button>
                            {{/if}}

                            {{!-- Ch7: Morale Attack button for Display Kill / Threaten --}}
                            {{#if set.maneuverOutcome.hasMoraleAttack}}
                                <button class="reign-btn-small reign-btn-morale apply-morale-btn" data-morale-value="{{set.maneuverOutcome.moraleAttack}}" data-source="{{localize set.maneuverOutcome.maneuverLabel}}" title="Apply Morale Attack {{set.maneuverOutcome.moraleAttack}} to targeted threat groups" {{#unless set.isSuccess}}disabled{{/unless}}>
                                    <i class="fas fa-skull-crossbones"></i> MA {{set.maneuverOutcome.moraleAttack}}
                                </button>
                            {{/if}}
                        </div>
                    </div>
                {{/each}}
            </div>
        {{else}}
            <div class="reign-banner reign-banner-fail">No Sets Found</div>
        {{/if}}
    </div>

    {{!-- Display the Gobble Dice counter or Selection Prompt on the Defense card --}}
    {{#if isDefense}}
        {{#if needsGobbleSelection}}
            <div class="reign-gobble-tracker" style="margin-top: 15px;">
                <div class="reign-section-title" style="color: var(--reign-orange); border-color: var(--reign-orange);">
                    <i class="fas fa-exclamation-triangle"></i> Select Gobble Dice
                </div>
                <div style="padding: 8px; text-align: center; color: var(--reign-text-dark); opacity: 0.8; font-style: italic; font-size: 0.9em;">
                    You rolled multiple sets! Click the <i class="fas fa-hand-pointer"></i> icon on a set above to lock it in as your active Gobble Dice.
                </div>
            </div>
        {{else}}
            <div class="reign-gobble-tracker">
                <div class="reign-section-title" style="color: var(--reign-blue); border-color: var(--reign-blue);">
                    <i class="fas fa-shield-alt"></i> Available Gobble Dice ({{gobbleCount}})
                </div>
                <div class="dice-tray wrap gobble-list">
                    {{#if gobbleDice.length}}
                        {{#each gobbleDice as |die|}}
                            <div class="reign-die gobble-badge" title="Available Gobble Die">{{die}}</div>
                        {{/each}}
                    {{else}}
                        <span class="reign-text-danger reign-text-bold reign-text-muted">All Gobble Dice Spent!</span>
                    {{/if}}
                </div>
            </div>
        {{/if}}
    {{/if}}

    <div class="reign-callout">
        <div class="reign-section-title">Unmatched Dice (Waste)</div>
        <div class="dice-tray wrap">
            {{#if waste.length}}
                {{#each waste as |die|}}
                    <div class="reign-die waste" title="Waste Die">{{die.value}}</div>
                {{/each}}
            {{else}}
                <span class="reign-text-muted">None</span>
            {{/if}}
        </div>
        
        {{!-- Waste Hit/Heal UI Block --}}
        {{#if wasteDmg}}
            <div class="reign-heal-tags">
                <div style="color: {{#if wasteDmg.isHealing}}var(--reign-green){{else}}var(--reign-red){{/if}};">
                    <strong>Waste Effect:</strong><br>
                    1 {{wasteDmg.type}} to {{wasteDmg.locations}}
                </div>
                <button class="reign-btn-small apply-waste-dmg-btn {{#if wasteDmg.isHealing}}reign-btn-heal{{else}}reign-btn-waste-dmg{{/if}}" data-faces="{{wasteDmg.faces}}" data-type="{{wasteDmg.type}}" data-ap="{{wasteDmg.ap}}" title="Apply Waste {{#if wasteDmg.isHealing}}Healing{{else}}Hits{{/if}}">
                    <i class="fas {{#if wasteDmg.isHealing}}fa-heartbeat{{else}}fa-meteor{{/if}}"></i>
                </button>
            </div>
        {{/if}}
    </div>

    {{#if (gt expertDie 0)}}
        <div class="reign-ed-result">
            <strong>Expert Die Face:</strong> <span class="reign-ed-badge">{{expertDie}}</span>
        </div>
    {{/if}}
    {{#if (gt masterDiceCount 0)}}
        <div class="reign-md-result">
            <strong>Master Dice Used:</strong> <span>{{masterDiceCount}}</span>
        </div>
    {{/if}}
</div>