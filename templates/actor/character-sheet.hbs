<div class="reign-sheet-root">
  <header class="sheet-header">
    <div class="header-top">
      <img src="{{actor.img}}" data-action="editImage" title="{{actor.name}}" class="profile-img"/>
      <div class="header-fields">
        <div class="title-row">
          <input name="name" type="text" value="{{actor.name}}" placeholder="CHARACTER NAME"/>
          <input name="system.biography.company" type="text" value="{{system.biography.company}}" placeholder="COMPANY NAME"/>
        </div>
        <div class="narrative-row">
          <div class="narrative-box"><label>{{localize 'REIGN.Mission'}}</label><input type="text" name="system.biography.mission" value="{{system.biography.mission}}"/></div>
          <div class="narrative-box"><label>{{localize 'REIGN.Duty'}}</label><input type="text" name="system.biography.duty" value="{{system.biography.duty}}"/></div>
          <div class="narrative-box"><label>{{localize 'REIGN.Craving'}}</label><input type="text" name="system.biography.craving" value="{{system.biography.craving}}"/></div>
        </div>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs">
    <a class="item {{tabs.stats}}" data-action="changeTab" data-tab="stats">STATS</a>
    <a class="item {{tabs.combat}}" data-action="changeTab" data-tab="combat">COMBAT</a>
    <a class="item {{tabs.esoterica}}" data-action="changeTab" data-tab="esoterica">ESOTERICA</a>
    <a class="item {{tabs.biography}}" data-action="changeTab" data-tab="biography">BIOGRAPHY</a>
    <a class="item {{tabs.effects}}" data-action="changeTab" data-tab="effects">EFFECTS</a>
  </nav>

  <section class="sheet-body">
    
    {{!-- PAGE 1: STATS & SKILLS --}}
    <div class="tab stats {{tabs.stats}}" data-tab="stats">
      
      <div class="xp-tracker stat-block reign-mb20">
        <div class="stat-header" style="display: flex; align-items: center; justify-content: space-between; padding: 8px 15px;">
          <div style="display: flex; align-items: center; gap: 20px;">
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="font-weight: bold; font-size: 1.1em; color: #fff;">Unspent XP</span>
              <input type="number" name="system.xp.value" value="{{system.xp.value}}" style="width: 60px; text-align: center; color: #000; background: #fff;" title="Available to spend"/>
            </div>
            <div style="display: flex; align-items: center; gap: 8px;">
              <span style="font-weight: bold; font-size: 1.1em; color: #fff;">Total XP Spent</span>
              <input type="number" name="system.xp.spent" value="{{system.xp.spent}}" style="width: 60px; text-align: center; color: #000; background: #fff;" title="Lifetime spent"/>
            </div>
          </div>
          <div style="display: flex; align-items: center; gap: 15px;">
            <button type="button" data-action="generateCharacter" style="background: rgba(255,255,255,0.2); border: 1px solid #fff; border-radius: 3px; color: #fff; cursor: pointer; padding: 2px 8px; font-size: 0.9em; font-weight: bold; height: 26px;" title="Roll 11d10 to automatically build character">
              <i class="fas fa-dice-d10"></i> One-Roll Generator
            </button>
            <a data-action="toggleProgression" class="{{#if progressionMode}}active-mode{{/if}}" title="{{localize 'REIGN.ProgressionModeDesc'}}" style="color: #fff;">
              <i class="fas {{#if progressionMode}}fa-toggle-on{{else}}fa-toggle-off{{/if}}"></i> {{localize 'REIGN.ProgressionMode'}}
            </a>
          </div>
        </div>
      </div>

      <div class="stat-grid">
        {{#each reignStatBlocks as |block|}}
        <div class="stat-block">
          <div class="stat-header">
            {{#if @root.progressionMode}}
              <h2 class="upgrade-btn" data-action="upgradeStat" data-type="attribute" data-key="{{block.key}}" data-label="{{block.label}}">{{block.label}} <i class="fas fa-arrow-up"></i></h2>
            {{else}}
              <h2 class="rollable" data-action="rollStat" data-type="attribute" data-key="{{block.key}}" data-label="{{block.label}}">{{block.label}} <i class="fas fa-dice"></i></h2>
            {{/if}}
            <input type="number" name="system.attributes.{{block.key}}.value" value="{{block.value}}"/>
          </div>
          <div class="stat-skills">
            {{#each block.skills as |skill|}}
            <div class="skill-row">
              {{#if skill.isCustom}}
                <div class="custom-skill-label">
                  <a class="delete-custom-skill" data-action="deleteCustomSkill" data-skill-id="{{skill.key}}" title="Delete Skill"><i class="fas fa-trash"></i></a>
                  {{#if @root.progressionMode}}
                    <label class="upgrade-btn" data-action="upgradeStat" data-type="customSkill" data-key="{{skill.key}}" data-label="{{skill.customLabel}}"><i class="fas fa-arrow-up"></i></label>
                  {{else}}
                    <label class="rollable" data-action="rollStat" data-type="customSkill" data-key="{{skill.key}}" data-label="{{skill.customLabel}}"><i class="fas fa-dice"></i></label>
                  {{/if}}
                  <input type="text" name="system.customSkills.{{skill.key}}.customLabel" value="{{skill.customLabel}}" placeholder="Skill Name..."/>
                </div>
              {{else}}
                {{#if @root.progressionMode}}
                  <label class="upgrade-btn" data-action="upgradeStat" data-type="skill" data-key="{{skill.key}}" data-label="{{skill.label}}">{{skill.label}} <i class="fas fa-arrow-up"></i></label>
                {{else}}
                  <label class="rollable" data-action="rollStat" data-type="skill" data-key="{{skill.key}}" data-label="{{skill.label}}">{{skill.label}} <i class="fas fa-dice"></i></label>
                {{/if}}
              {{/if}}
              <div class="em-toggles">
                {{#if skill.isCustom}}
                  <label class="em-label" title="{{localize 'REIGN.IsCombatSkill'}}">C <input type="checkbox" name="system.customSkills.{{skill.key}}.isCombat" {{checked skill.isCombat}} {{#if @root.progressionMode}}disabled{{/if}}/></label>
                {{/if}}

                {{#if @root.progressionMode}}
                  <a class="em-label {{#unless skill.expert}}upgrade-btn{{/unless}}" title="Upgrade to Expert Die"
                     {{#unless skill.expert}}data-action="upgradeStat" data-type="ed" data-key="{{skill.key}}" data-iscustom="{{skill.isCustom}}" data-label="{{#if skill.isCustom}}{{skill.customLabel}}{{else}}{{skill.label}}{{/if}}"{{/unless}}>
                    E {{#if skill.expert}}<i class="fas fa-check" style="color:green"></i>{{else}}<i class="fas fa-arrow-up"></i>{{/if}}
                  </a>
                  <a class="em-label {{#unless skill.master}}upgrade-btn{{/unless}}" title="Upgrade to Master Die"
                     {{#unless skill.master}}data-action="upgradeStat" data-type="md" data-key="{{skill.key}}" data-iscustom="{{skill.isCustom}}" data-label="{{#if skill.isCustom}}{{skill.customLabel}}{{else}}{{skill.label}}{{/if}}" data-hased="{{skill.expert}}"{{/unless}}>
                    M {{#if skill.master}}<i class="fas fa-check" style="color:green"></i>{{else}}<i class="fas fa-arrow-up"></i>{{/if}}
                  </a>
                {{else}}
                  <label class="em-label" title="{{localize 'REIGN.ExpertDie'}}">E <input type="checkbox" name="{{#if skill.isCustom}}system.customSkills.{{skill.key}}.expert{{else}}system.skills.{{skill.key}}.expert{{/if}}" {{checked skill.expert}}/></label>
                  <label class="em-label" title="{{localize 'REIGN.MasterDie'}}">M <input type="checkbox" name="{{#if skill.isCustom}}system.customSkills.{{skill.key}}.master{{else}}system.skills.{{skill.key}}.master{{/if}}" {{checked skill.master}}/></label>
                {{/if}}
              </div>
              <input type="number" name="{{#if skill.isCustom}}system.customSkills.{{skill.key}}.value{{else}}system.skills.{{skill.key}}.value{{/if}}" value="{{skill.value}}"/>
            </div>
            {{/each}}
            <div class="custom-add-container">
              <a class="add-custom-skill control-btn" data-action="addCustomSkill" data-attr="{{block.key}}"><i class="fas fa-plus"></i> {{localize 'REIGN.AddSkill'}}</a>
            </div>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- PAGE 2: COMBAT --}}
    <div class="tab combat {{tabs.combat}}" data-tab="combat">
      
      <div class="reign-health-container reign-mb20">
        {{!-- Tier 1: Column Header Labels --}}
        <header class="health-labels-header">
            <div>Location</div>
            <div class="label-center">Health Track</div>
            <div class="label-right">AR</div>
        </header>

        {{!-- Tier 2: Action & Badge Sub-Header (ALIGNED TO GRID) --}}
        <div class="health-actions-sub-header">
            <span class="health-hint">(L-Click: Add, R-Click: Remove)</span>
            
            <div class="label-center" style="display: flex; gap: 5px; justify-content: center;">
                <button type="button" data-action="recoverShock" class="recovery-btn" title="Halve current Shock damage (Post-Combat)">
                  <i class="fas fa-heartbeat"></i> Short Rest
                </button>
                <button type="button" data-action="restAndRecover" class="recovery-btn" title="Natural Healing (1 Day / 1 Week)">
                  <i class="fas fa-campground"></i> Long Rest
                </button>
            </div>

            <div class="label-right">
                {{#if activeShields.length}}
                  <div class="shield-badge" title="Active Shield Protection (RAW Round Declaration)">
                    <i class="fas fa-shield-alt"></i> {{activeShields.[0].system.shieldSize}}
                  </div>
                {{/if}}
            </div>
        </div>

        {{!-- Data Rows --}}
        <div class="health-body">
          {{#each reignHealth as |loc|}}
          <div class="reign-health-row">
            <div class="location-label-group">
              {{#if @root.activeShields.length}}
                <a class="shield-toggle {{#if loc.isShielded}}active{{/if}}" 
                   data-action="toggleShieldLocation" 
                   data-loc="{{loc.key}}" 
                   data-shield-id="{{@root.activeShields.[0].id}}" 
                   title="Protect this location">
                  <i class="fas fa-shield-alt"></i>
                </a>
              {{/if}}
              <span class="loc-text">{{loc.label}}</span>
            </div>

            <div class="health-track" data-loc="{{loc.key}}">
              {{#each loc.boxes as |box|}}
                  <div class="health-box" data-state="{{box.state}}">{{box.icon}}</div>
              {{/each}}
            </div>

            <div class="reign-ar-badge-col">
                <input type="number" value="{{loc.armor}}" class="reign-ar-input" title="Total AR (Auto-Calculated from Equipped Items)" readonly tabindex="-1" style="background: rgba(0,0,0,0.05); color: #2d5a27; font-weight: bold; border: 1px solid #ccc; cursor: default;"/>
            </div>
          </div>
          {{/each}}
        </div>
      </div>

      {{!-- PREFERRED MOVES --}}
      <div class="stat-block reign-mb20">
        <div class="stat-header"><h2>{{localize 'REIGN.PreferredMoves'}}</h2></div>
        <div class="stat-skills reign-move-list">
            <div class="preferred-move-row">
              <label class="rollable" data-action="rollStat" data-type="skill" data-key="parry" data-label="Parry">{{localize 'REIGN.ParryPool'}} <i class="fas fa-dice"></i></label>
              <div class="move-details">
                <span>Body ({{preferredMoves.body}}) + Parry ({{preferredMoves.parry}}){{#if preferredMoves.shieldBonus}} + Shield ({{preferredMoves.shieldBonus}}){{/if}} =</span>
                <span class="move-total">{{preferredMoves.parryTotal}}</span>
              </div>
            </div>
            <div class="preferred-move-row">
              <label class="rollable" data-action="rollStat" data-type="skill" data-key="dodge" data-label="Dodge">{{localize 'REIGN.DodgePool'}} <i class="fas fa-dice"></i></label>
              <div class="move-details">
                <span>Coordination ({{preferredMoves.coord}}) + Dodge ({{preferredMoves.dodge}}) =</span>
                <span class="move-total">{{preferredMoves.dodgeTotal}}</span>
              </div>
            </div>
            {{#each customMoves as |move|}}
            <div class="preferred-move-row dynamic-move">
              <div class="reign-move-row">
                <a class="delete-custom-move" data-action="deleteCustomMove" data-move-id="{{move.key}}" title="Delete Move"><i class="fas fa-trash"></i></a>
                <label class="rollable" data-action="rollStat" data-type="move" data-key="{{move.key}}" data-label="{{move.name}}"><i class="fas fa-dice"></i></label>
                <input type="text" name="system.customMoves.{{move.key}}.name" value="{{move.name}}" placeholder="Move Name..." class="move-name-input"/>
                <div class="move-details">
                  <span class="reign-move-total-label">{{localize 'REIGN.Total'}}:</span>
                  <span class="move-total reign-move-total-val">{{move.total}}</span>
                </div>
              </div>
              <div class="move-builder">
                <select name="system.customMoves.{{move.key}}.attrKey">
                  {{selectOptions ../attributeOptions selected=move.attrKey}}
                </select>
                <span>+</span>
                <select name="system.customMoves.{{move.key}}.skillKey">
                  {{selectOptions ../skillOptions selected=move.skillKey}}
                </select>
                <span class="reign-ml15">+ {{localize 'REIGN.Mod'}}:</span>
                <input type="number" name="system.customMoves.{{move.key}}.modifier" value="{{move.modifier}}"/>
              </div>
            </div>
            {{/each}}
            <div class="custom-add-container reign-add-move-btn">
              <a class="add-custom-skill control-btn" data-action="addCustomMove"><i class="fas fa-plus"></i> {{localize 'REIGN.AddQuickMove'}}</a>
            </div>
        </div>
      </div>

      <div class="item-list-container reign-mb20">
        <div class="list-header flexrow">
          <h3 class="reign-col-2">{{localize 'REIGN.Weapon'}}</h3>
          <span class="reign-col-1" style="text-align: center;" title="{{localize 'REIGN.Equipped'}}"><i class="fas fa-hand-paper"></i></span>
          <span class="reign-col-1">{{localize 'REIGN.Damage'}}</span>
          <span class="reign-col-1">{{localize 'REIGN.AttackPool'}}</span>
          <span class="reign-col-1">{{localize 'REIGN.Range'}}</span>
          <span class="reign-col-2">{{localize 'REIGN.Notes'}}</span>
          <a class="item-create control-btn" data-action="itemCreate" data-type="weapon" title="Add Weapon"><i class="fas fa-plus"></i></a>
        </div>
        {{#each weapons as |item|}}
        <div class="item-row flexrow">
          <span class="item-name reign-col-2 reign-bold">
            <label class="rollable" data-action="rollStat" data-type="item" data-key="{{item.id}}" data-label="{{item.name}}"><i class="fas fa-dice reign-mr10"></i></label>
            {{item.name}}
          </span>
          <span class="reign-col-1" style="display: flex; justify-content: center; align-items: center;">
            <input type="checkbox" data-action="toggleEquip" data-item-id="{{item.id}}" {{checked item.system.equipped}} style="margin: 0; cursor: pointer;" title="Toggle Equip Weapon"/>
          </span>
          <span class="reign-col-1">{{item.system.damage}}</span>
          <span class="reign-col-1">{{item.system.pool}}</span>
          <span class="reign-col-1">{{item.system.range}}</span>
          <span class="reign-col-2 reign-item-subtext">{{item.system.notes}}</span>
          <div class="item-controls">
            <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
            <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
            <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>

      {{!-- MOVED SHIELDS INTO COMBAT TAB --}}
      <div class="item-list-container reign-mb20">
        <div class="list-header flexrow">
          <h3 class="reign-col-2">Shield</h3>
          <span class="reign-col-1" style="text-align: center;" title="{{localize 'REIGN.Equipped'}}">
            <i class="fas fa-shield-alt"></i>
          </span>
          <span class="reign-col-1" style="text-align: center;" title="{{localize 'REIGN.ParryBonus'}}">Parry</span>
          <span class="reign-col-2"></span>
          <a class="item-create control-btn" data-action="itemCreate" data-type="shield" title="Add Shield">
            <i class="fas fa-plus"></i>
          </a>
        </div>
        {{#each shields as |item|}}
        <div class="item-row flexrow">
          <span class="reign-col-2 reign-bold">{{item.name}}</span>
          <span class="reign-col-1" style="display: flex; justify-content: center; align-items: center;">
            <input type="checkbox" data-action="toggleEquip" data-item-id="{{item.id}}" {{checked item.system.equipped}} style="margin: 0; cursor: pointer;" title="{{localize 'REIGN.Equipped'}}"/>
          </span>
          <span class="reign-col-1" style="text-align: center;">+{{item.system.parryBonus}}d</span>
          <span class="reign-col-2" style="display: flex; align-items: center; justify-content: center;">
            {{#if (eq item.system.shieldSize "tower")}}
              <a class="item-control" data-action="toggleStationary" data-item-id="{{item.id}}" title="Tower Shield: Toggle Stationary vs Moving Coverage" style="cursor: pointer; color: {{#if item.system.isStationary}}#2d5a27{{else}}#999{{/if}}; font-size: 0.85em; display: flex; align-items: center; justify-content: center; gap: 5px;">
                <i class="fas {{#if item.system.isStationary}}fa-anchor{{else}}fa-walking{{/if}}"></i> {{#if item.system.isStationary}}Stationary{{else}}Moving{{/if}}
              </a>
            {{/if}}
          </span>
          <div class="item-controls">
            <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
            <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
            <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>

      <div class="item-list-container reign-mt20">
        <div class="list-header flexrow">
          <h3 class="reign-col-2">{{localize 'REIGN.MartialTechnique'}}</h3>
          <span class="reign-col-1">{{localize 'REIGN.Path'}}</span>
          <span class="reign-col-1">{{localize 'REIGN.Pool'}}</span>
          <span class="reign-col-1">{{localize 'REIGN.Page'}}</span>
          <span class="reign-col-3">{{localize 'REIGN.Effect'}}</span>
          <a class="item-create control-btn" data-action="itemCreate" data-type="technique"><i class="fas fa-plus"></i></a>
        </div>
        {{#each techniques as |item|}}
        <div class="item-row flexrow">
          <span class="item-name reign-col-2 reign-bold">
            <label class="rollable" data-action="rollStat" data-type="item" data-key="{{item.id}}" data-label="{{item.name}}"><i class="fas fa-dice reign-mr10"></i></label>
            {{item.name}}
          </span>
          <span class="reign-col-1">{{item.system.path}}</span>
          <span class="reign-col-1">{{item.system.pool}}</span>
          <span class="reign-col-1">{{item.system.page}}</span>
          <span class="reign-col-3 reign-item-subtext">{{item.system.effect}}</span>
          <div class="item-controls">
            <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
            <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
            <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- PAGE 3: ESOTERICA --}}
    <div class="tab esoterica {{tabs.esoterica}}" data-tab="esoterica">
      <div class="item-list-container reign-mb20">
        <div class="list-header flexrow">
          <h3 class="reign-col-2">{{localize 'REIGN.EsotericDisciplines'}}</h3>
          <span class="reign-col-1">{{localize 'REIGN.Rank'}}</span>
          <span class="reign-col-1">{{localize 'REIGN.Page'}}</span>
          <span class="reign-col-3">{{localize 'REIGN.Effect'}}</span>
          <a class="item-create control-btn" data-action="itemCreate" data-type="discipline"><i class="fas fa-plus"></i></a>
        </div>
        {{#each disciplines as |item|}}
        <div class="item-row flexrow">
          <span class="reign-col-2 reign-bold">{{item.name}}</span>
          <span class="reign-col-1">{{item.system.rank}}</span>
          <span class="reign-col-1 reign-item-subtext">{{item.system.page}}</span>
          <span class="reign-col-3 reign-item-subtext">{{item.system.effect}}</span>
          <div class="item-controls">
            <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
            <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
            <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
          </div>
        </div>
        {{/each}}
      </div>

      <div class="reign-esoterica-split">
        <div class="reign-magic-stats">
          <div class="stat-block">
            <div class="stat-header" style="display: flex; align-items: center; justify-content: space-between; padding: 4px 15px;">
              {{#if @root.progressionMode}}
                <h2 class="upgrade-btn" data-action="upgradeStat" data-type="esoterica" data-key="sorcery" data-label="Sorcery" style="margin: 0; border: none;">{{localize 'REIGN.Sorcery'}} <i class="fas fa-arrow-up"></i></h2>
              {{else}}
                <h2 class="rollable" data-action="rollStat" data-type="esoterica" data-key="sorcery" data-label="Sorcery" style="margin: 0; border: none;">{{localize 'REIGN.Sorcery'}} <i class="fas fa-dice"></i></h2>
              {{/if}}
              
              <div class="em-toggles" style="display: flex; gap: 12px; color: #fff;">
                {{#if @root.progressionMode}}
                  <a class="em-label {{#unless system.esoterica.expert}}upgrade-btn{{/unless}}" style="color: #fff;" title="Upgrade to Expert Die"
                     {{#unless system.esoterica.expert}}data-action="upgradeStat" data-type="ed" data-key="sorcery" data-label="Sorcery" data-isesoterica="true"{{/unless}}>
                    E {{#if system.esoterica.expert}}<i class="fas fa-check" style="color:#4ade80"></i>{{else}}<i class="fas fa-arrow-up"></i>{{/if}}
                  </a>
                  <a class="em-label {{#unless system.esoterica.master}}upgrade-btn{{/unless}}" style="color: #fff;" title="Upgrade to Master Die"
                     {{#unless system.esoterica.master}}data-action="upgradeStat" data-type="md" data-key="sorcery" data-label="Sorcery" data-isesoterica="true" data-hased="{{system.esoterica.expert}}"{{/unless}}>
                    M {{#if system.esoterica.master}}<i class="fas fa-check" style="color:#4ade80"></i>{{else}}<i class="fas fa-arrow-up"></i>{{/if}}
                  </a>
                {{else}}
                  <label class="em-label" style="color: #fff; cursor: pointer; display: flex; align-items: center; gap: 4px;" title="{{localize 'REIGN.ExpertDie'}}">E <input type="checkbox" name="system.esoterica.expert" {{checked system.esoterica.expert}}/></label>
                  <label class="em-label" style="color: #fff; cursor: pointer; display: flex; align-items: center; gap: 4px;" title="{{localize 'REIGN.MasterDie'}}">M <input type="checkbox" name="system.esoterica.master" {{checked system.esoterica.master}}/></label>
                {{/if}}
              </div>
            </div>
            
            <div class="reign-sorcery-box" style="padding: 10px; display: flex; justify-content: center;">
              <input type="number" name="system.esoterica.sorcery" value="{{system.esoterica.sorcery}}" class="reign-sorcery-val" style="width: 60px; height: 40px; font-size: 1.5em; text-align: center; border: 2px solid #000;"/>
            </div>
            <div class="reign-quick-attrs">
              <div class="reign-quick-attrs-title">{{localize 'REIGN.CastingAttributes'}}</div>
              <div class="quick-attr-row"><span>Body:</span> <strong>{{system.attributes.body.value}}</strong></div>
              <div class="quick-attr-row"><span>Coordination:</span> <strong>{{system.attributes.coordination.value}}</strong></div>
              <div class="quick-attr-row"><span>Sense:</span> <strong>{{system.attributes.sense.value}}</strong></div>
              <div class="quick-attr-row"><span>Knowledge:</span> <strong>{{system.attributes.knowledge.value}}</strong></div>
              <div class="quick-attr-row"><span>Command:</span> <strong>{{system.attributes.command.value}}</strong></div>
              <div class="quick-attr-row"><span>Charm:</span> <strong>{{system.attributes.charm.value}}</strong></div>
            </div>
          </div>
          <div class="stat-block reign-attunement-box">
            <div class="stat-header reign-flex-center"><h2 style="font-size: 0.9em;">{{localize 'REIGN.AttunementEffects'}}</h2></div>
            <textarea name="system.esoterica.attunement" placeholder="{{localize 'REIGN.AttunementPlaceholder'}}" class="reign-textarea">{{system.esoterica.attunement}}</textarea>
          </div>
        </div>

        <div class="item-list-container reign-spell-list">
          <div class="list-header flexrow">
            <h3 class="reign-col-2">{{localize 'REIGN.Spells'}}</h3>
            <span class="reign-col-1">{{localize 'REIGN.Pool'}}</span>
            <span class="reign-col-1">{{localize 'REIGN.Intensity'}}</span>
            <span class="reign-col-1">{{localize 'REIGN.Page'}}</span>
            <span class="reign-col-3">{{localize 'REIGN.Effect'}}</span>
            <a class="item-create control-btn" data-action="itemCreate" data-type="spell"><i class="fas fa-plus"></i></a>
          </div>
          <div class="reign-spell-scroll">
            {{#each spells as |item|}}
            <div class="item-row flexrow">
              <span class="reign-col-2 reign-bold">
                <label class="rollable" data-action="rollStat" data-type="item" data-key="{{item.id}}" data-label="{{item.name}}"><i class="fas fa-dice reign-mr10"></i></label>
                {{item.name}}
              </span>
              <span class="reign-col-1">{{item.system.pool}}</span>
              <span class="reign-col-1 reign-intensity-val">{{item.system.intensity}}</span>
              <span class="reign-col-1 reign-item-subtext">{{item.system.page}}</span>
              <span class="reign-col-3 reign-item-subtext">{{item.system.effect}}</span>
              <div class="item-controls">
                <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
                <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
                <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
      </div>
    </div>

    {{!-- PAGE 4: BIOGRAPHY --}}
    <div class="tab biography {{tabs.biography}}" data-tab="biography">
      <div class="stat-grid">
        <div class="reign-bio-left">
          <div class="stat-block reign-mb20">
            <div class="stat-header"><h2>{{localize 'REIGN.HistorySecrets'}}</h2></div>
            <textarea name="system.biography.history" class="reign-textarea-120">{{system.biography.history}}</textarea>
          </div>

          <div class="item-list-container reign-mb20">
            <div class="list-header flexrow">
              <h3 class="reign-col-3">{{localize 'REIGN.Advantage'}}</h3>
              <span class="reign-col-1">{{localize 'REIGN.CostXP'}}</span>
              <a class="item-create control-btn" data-action="itemCreate" data-type="advantage" title="Add Advantage"><i class="fas fa-plus"></i></a>
            </div>
            {{#each advantages as |item|}}
            <div class="item-row flexrow">
              <span class="reign-col-3 reign-bold">{{item.name}}</span>
              <span class="reign-col-1">{{item.system.cost}}</span>
              <div class="item-controls">
                <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
                <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
                <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            {{/each}}
          </div>

          <div class="item-list-container">
            <div class="list-header flexrow">
              <h3 class="reign-col-3">{{localize 'REIGN.Problem'}}</h3>
              <span class="reign-col-1">{{localize 'REIGN.BonusXP'}}</span>
              <a class="item-create control-btn" data-action="itemCreate" data-type="problem" title="Add Problem"><i class="fas fa-plus"></i></a>
            </div>
            {{#each problems as |item|}}
            <div class="item-row flexrow">
              <span class="reign-col-3 reign-bold">{{item.name}}</span>
              <span class="reign-col-1">{{item.system.bonus}}</span>
              <div class="item-controls">
                <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
                <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
                <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            {{/each}}
          </div>
        </div>

        <div class="reign-bio-right">
          <div class="stat-block reign-mb20">
            <div class="stat-header" style="display: flex; align-items: center; justify-content: space-between; padding: 8px 15px;">
              <h2 style="margin: 0; border: none;">{{localize 'REIGN.Wealth'}}</h2>
              <div style="display: flex; gap: 5px;">
                <button type="button" data-action="acquireLoot" style="background: rgba(255,255,255,0.2); border: 1px solid #fff; border-radius: 3px; color: #fff; cursor: pointer; padding: 2px 8px; font-size: 0.9em; font-weight: bold; height: 26px;" title="Acquire new treasure and evaluate it against your Wealth">
                  <i class="fas fa-coins"></i> Acquire Loot
                </button>
                <button type="button" data-action="purchaseHelper" style="background: rgba(255,255,255,0.2); border: 1px solid #fff; border-radius: 3px; color: #fff; cursor: pointer; padding: 2px 8px; font-size: 0.9em; font-weight: bold; height: 26px;" title="{{localize 'REIGN.PurchaseHelperDesc'}}">
                  <i class="fas fa-coins"></i> {{localize 'REIGN.PurchaseHelper'}}
                </button>
              </div>
            </div>
            <div class="quality-stats flexrow" style="background: #fff; padding: 10px;">
              <div class="q-stat" style="flex: 1; align-items: center;">
                <input type="number" name="system.wealth.value" value="{{system.wealth.value}}" class="current-rating" min="0" max="10" style="width: 60px; height: 50px; font-size: 2em; text-align: center; border: 2px solid #000;"/>
              </div>
            </div>
          </div>
          
          <div class="item-list-container reign-mb20">
            <div class="list-header flexrow">
              <h3 class="reign-col-2">{{localize 'REIGN.Armor'}}</h3>
              <span class="reign-col-1" style="text-align: center;" title="{{localize 'REIGN.Equipped'}}"><i class="fas fa-tshirt"></i></span>
              <span class="reign-col-1" style="text-align: center;">Weight</span>
              <a class="item-create control-btn" data-action="itemCreate" data-type="armor" title="Add Armor"><i class="fas fa-plus"></i></a>
            </div>
            {{#each armors as |item|}}
            <div class="item-row flexrow">
              <span class="reign-col-2 reign-bold">{{item.name}}</span>
              <span class="reign-col-1" style="display: flex; justify-content: center; align-items: center;">
                <input type="checkbox" data-action="toggleEquip" data-item-id="{{item.id}}" {{checked item.system.equipped}} style="margin: 0; cursor: pointer;" title="{{localize 'REIGN.Equipped'}}"/>
              </span>
              <span class="reign-col-1 reign-item-subtext" style="text-align: center; text-transform: capitalize;">{{item.system.armorWeight}}</span>
              <div class="item-controls">
                <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
                <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
                <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            {{/each}}
          </div>

          <div class="item-list-container">
            <div class="list-header flexrow">
              <h3 class="reign-col-3">{{localize 'REIGN.GearCarried'}}</h3>
              <span class="reign-col-1">{{localize 'REIGN.Qty'}}</span>
              <a class="item-create control-btn" data-action="itemCreate" data-type="gear"><i class="fas fa-plus"></i></a>
            </div>
            {{#each gear as |item|}}
            <div class="item-row flexrow">
              <span class="reign-col-3">{{item.name}}</span>
              <span class="reign-col-1">{{item.system.quantity}}</span>
              <div class="item-controls">
                <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
                <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
                <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
      </div>
    </div>

    {{!-- PHASE 2: ACTIVE EFFECTS TAB --}}
    <div class="tab effects {{tabs.effects}}" data-tab="effects">
      <div class="reign-effects-tab-container">
        <h3 style="display: flex; justify-content: space-between; align-items: center; font-family: 'Book Antiqua', serif; border-bottom: 2px solid #8b1f1f; padding-bottom: 5px; margin-bottom: 15px;">
          <span>Ongoing Effects & Conditions</span>
          <a data-action="createEffect" title="Add Effect" style="font-size: 0.8em; cursor: pointer; color: #8b1f1f;">
            <i class="fas fa-plus"></i> Create Effect
          </a>
        </h3>

        {{#if effects.length}}
          <div class="effects-list" style="display: flex; flex-direction: column; gap: 8px;">
            {{#each effects as |effect|}}
              <div class="effect-item" data-effect-id="{{effect.id}}" style="display: flex; justify-content: space-between; align-items: center; background: #fff; border: 1px solid #ccc; border-left: 4px solid #8b1f1f; padding: 10px; border-radius: 3px;">
                <div style="display: flex; align-items: center; gap: 15px; {{#if effect.disabled}}opacity: 0.5;{{/if}}">
                  <img src="{{effect.img}}" style="width: 32px; height: 32px; border: none;"/>
                  <div style="display: flex; flex-direction: column;">
                    <span style="font-weight: bold; font-family: 'Book Antiqua', serif; font-size: 1.1em;">{{effect.name}}</span>
                    {{#if effect.disabled}}
                      <span style="font-size: 0.8em; color: #8b1f1f; font-style: italic;">(Disabled)</span>
                    {{/if}}
                  </div>
                </div>
                <div class="effect-controls" style="display: flex; gap: 12px;">
                  <a data-action="toggleEffect" title="{{#if effect.disabled}}Enable{{else}}Disable{{/if}}" style="cursor: pointer; font-size: 1.1em;">
                    <i class="fas {{#if effect.disabled}}fa-check-circle{{else}}fa-times-circle{{/if}}"></i>
                  </a>
                  <a data-action="editEffect" title="Edit" style="cursor: pointer; font-size: 1.1em;"><i class="fas fa-edit"></i></a>
                  <a data-action="deleteEffect" title="Delete" style="cursor: pointer; font-size: 1.1em; color: #8b1f1f;"><i class="fas fa-trash"></i></a>
                </div>
              </div>
            {{/each}}
          </div>
        {{else}}
          <p style="text-align: center; color: #666; font-style: italic; margin-top: 20px;">No ongoing effects or conditions active on this character.</p>
        {{/if}}
      </div>
    </div>

  </section>
</div>