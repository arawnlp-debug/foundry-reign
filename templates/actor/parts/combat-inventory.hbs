<div class="item-list-container reign-mb20">
  <div class="list-header flexrow">
    <h3 class="reign-col-2">{{localize 'REIGN.Weapon'}}</h3>
    <span class="reign-col-1 reign-text-center" title="{{localize 'REIGN.Equipped'}}"><i class="fas fa-hand-paper"></i></span>
    <span class="reign-col-1">{{localize 'REIGN.Damage'}}</span>
    <span class="reign-col-1">{{localize 'REIGN.AttackPool'}}</span>
    <span class="reign-col-1">{{localize 'REIGN.Range'}}</span>
    <span class="reign-col-2">{{localize 'REIGN.Notes'}}</span>
    <a class="item-create control-btn" data-action="itemCreate" data-type="weapon" title="Add Weapon"><i class="fas fa-plus"></i></a>
  </div>
  {{#each weapons as |item|}}
  <div class="item-row flexrow">
    <span class="item-name reign-col-2 reign-bold">
      <label class="rollable" data-action="rollStat" data-type="item" data-key="{{item.id}}" data-label="{{item.name}}"><i class="fas fa-dice-d10 reign-mr10"></i></label>
      {{item.name}}
    </span>
    <span class="reign-col-1 reign-flex-center">
      <input type="checkbox" data-action="toggleEquip" data-item-id="{{item.id}}" {{checked item.system.equipped}} class="reign-checkbox" title="Toggle Equip Weapon"/>
    </span>
    <span class="reign-col-1">{{item.system.damage}}</span>
    <span class="reign-col-1">{{item.system.pool}}</span>
    <span class="reign-col-1">{{item.system.range}}</span>
    <span class="reign-col-2 reign-item-subtext">{{item.system.notes}}</span>
    <div class="item-controls">
      <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
      <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
      <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
    </div>
  </div>
  {{/each}}
</div>

<div class="item-list-container reign-mb20">
  <div class="list-header flexrow">
    <h3 class="reign-col-2">Shield</h3>
    <span class="reign-col-1 reign-text-center" title="{{localize 'REIGN.Equipped'}}">
      <i class="fas fa-shield-alt"></i>
    </span>
    <span class="reign-col-1 reign-text-center" title="{{localize 'REIGN.ParryBonus'}}">Parry</span>
    <span class="reign-col-4"></span>
    <a class="item-create control-btn" data-action="itemCreate" data-type="shield" title="Add Shield">
      <i class="fas fa-plus"></i>
    </a>
  </div>
  {{#each shields as |item|}}
  <div class="item-row flexrow">
    <span class="reign-col-2 reign-bold">{{item.name}}</span>
    <span class="reign-col-1 reign-flex-center">
      <input type="checkbox" data-action="toggleEquip" data-item-id="{{item.id}}" {{checked item.system.equipped}} class="reign-checkbox" title="{{localize 'REIGN.Equipped'}}"/>
    </span>
    <span class="reign-col-1 reign-text-center">+{{item.system.parryBonus}}d</span>
    <span class="reign-col-4 reign-flex-center">
      {{#if (eq item.system.shieldSize "tower")}}
        <a class="item-control reign-tower-toggle {{#if item.system.isStationary}}active{{/if}}" data-action="toggleStationary" data-item-id="{{item.id}}" title="Tower Shield: Toggle Stationary vs Moving Coverage">
          <i class="fas {{#if item.system.isStationary}}fa-anchor{{else}}fa-walking{{/if}}"></i> {{#if item.system.isStationary}}Stationary{{else}}Moving{{/if}}
        </a>
      {{/if}}
    </span>
    <div class="item-controls">
      <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
      <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
      <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
    </div>
  </div>
  {{/each}}
</div>

<div class="item-list-container reign-mt20">
  <div class="list-header flexrow">
    <h3 class="reign-col-2">{{localize 'REIGN.MartialTechnique'}}</h3>
    <span class="reign-col-1">{{localize 'REIGN.Path'}}</span>
    <span class="reign-col-1">{{localize 'REIGN.Pool'}}</span>
    <span class="reign-col-1">{{localize 'REIGN.Page'}}</span>
    <span class="reign-col-3">{{localize 'REIGN.Effect'}}</span>
    <a class="item-create control-btn" data-action="itemCreate" data-type="technique"><i class="fas fa-plus"></i></a>
  </div>
  {{#each techniques as |item|}}
  <div class="item-row flexrow">
    <span class="item-name reign-col-2 reign-bold">
      <label class="rollable" data-action="rollStat" data-type="item" data-key="{{item.id}}" data-label="{{item.name}}"><i class="fas fa-dice-d10 reign-mr10"></i></label>
      {{item.name}}
    </span>
    <span class="reign-col-1">{{item.system.path}}</span>
    <span class="reign-col-1">{{item.system.pool}}</span>
    <span class="reign-col-1">{{item.system.page}}</span>
    <span class="reign-col-3 reign-item-subtext">{{item.system.effect}}</span>
    <div class="item-controls">
      <a data-action="itemToChat" data-item-id="{{item.id}}"><i class="fas fa-comment"></i></a>
      <a data-action="itemEdit" data-item-id="{{item.id}}"><i class="fas fa-edit"></i></a>
      <a data-action="itemDelete" data-item-id="{{item.id}}"><i class="fas fa-trash"></i></a>
    </div>
  </div>
  {{/each}}
</div>