<div class="reign-item-root">
  <header class="item-header flexrow">
    <img src="{{item.img}}" data-action="editImage" title="{{item.name}}" class="profile-img item-profile-img"/>
    <div class="header-details">
      <input name="name" type="text" value="{{item.name}}" placeholder="{{localize 'REIGN.ItemName'}}"/>
      <span class="item-type-label">{{item.type}}</span>
    </div>
  </header>

  {{!-- TAB NAVIGATION --}}
  <nav class="sheet-tabs tabs" style="display: flex; gap: 15px; border-bottom: 2px solid var(--reign-bg-iron); padding-bottom: 5px; margin-bottom: 10px;">
    <a class="item reign-bold reign-cursor-pointer" style="{{#if tabs.details}}color: var(--reign-color-blood); border-bottom: 2px solid var(--reign-color-blood);{{/if}}" data-action="changeTab" data-tab="details">Item Details</a>
    <a class="item reign-bold reign-cursor-pointer" style="{{#if tabs.effects}}color: var(--reign-color-blood); border-bottom: 2px solid var(--reign-color-blood);{{/if}}" data-action="changeTab" data-tab="effects">Active Effects</a>
  </nav>

  <section class="item-body sheet-body reign-scroll-y">
    
    {{!-- ========================================== --}}
    {{!-- DETAILS TAB --}}
    {{!-- ========================================== --}}
    <div class="tab {{tabs.details}}" data-tab="details" style="{{#unless tabs.details}}display: none;{{/unless}}">
      
      {{!-- WEAPON ITEM UI --}}
      {{#if isWeapon}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.DamageFormula'}}</label>
          <input type="text" name="system.damage" value="{{system.damage}}" placeholder="{{localize 'REIGN.SpellDamagePlaceholder'}}"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.AttackPool'}}</label>
          <input type="text" name="system.pool" value="{{system.pool}}"/>
        </div>
        <div class="form-group cm-col-span-2">
          <label>{{localize 'REIGN.RangeReach'}}</label>
          <input type="text" name="system.range" value="{{system.range}}"/>
        </div>
      </div>
      
      <div class="form-group reign-box-weapon">
        <label class="reign-bold">{{localize 'REIGN.WeaponQualities'}}</label>
        <div class="checkbox-group">
          <label><input type="number" name="system.qualities.armorPiercing" value="{{system.qualities.armorPiercing}}" class="cm-input-small"/> {{localize 'REIGN.ArmorPiercing'}}</label>
          <label><input type="number" name="system.qualities.slow" value="{{system.qualities.slow}}" class="cm-input-small"/> {{localize 'REIGN.Slow'}}</label>
          <label><input type="checkbox" name="system.qualities.twoHanded" {{checked system.qualities.twoHanded}}/> {{localize 'REIGN.TwoHanded'}}</label>
          <label><input type="checkbox" name="system.qualities.massive" {{checked system.qualities.massive}}/> {{localize 'REIGN.Massive'}}</label>
          <label><input type="number" name="system.qualities.area" value="{{system.qualities.area}}" class="cm-input-small"/> {{localize 'REIGN.AreaSplash'}}</label>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.NotesEffects'}}</label>
        <textarea name="system.notes">{{system.notes}}</textarea>
      </div>
      {{/if}}

      {{!-- ARMOR ITEM UI --}}
      {{#if isArmor}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.ArmorWeight'}}</label>
          <select name="system.armorWeight" class="cm-w100">
            {{selectOptions armorWeightOptions selected=system.armorWeight localize=true}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.ArmorRating'}}</label>
          <input type="number" name="system.ar" value="{{system.ar}}" min="0"/>
        </div>
      </div>
      <div class="form-group reign-box-weapon">
        <label class="reign-bold">{{localize 'REIGN.ProtectedLocations'}}</label>
        <div class="checkbox-group cm-mt5">
          <label><input type="checkbox" name="system.protectedLocations.head" {{checked system.protectedLocations.head}}/> {{localize 'REIGN.LocHead'}}</label>
          <label><input type="checkbox" name="system.protectedLocations.torso" {{checked system.protectedLocations.torso}}/> {{localize 'REIGN.LocTorso'}}</label>
          <label><input type="checkbox" name="system.protectedLocations.armR" {{checked system.protectedLocations.armR}}/> {{localize 'REIGN.LocRightArm'}}</label>
          <label><input type="checkbox" name="system.protectedLocations.armL" {{checked system.protectedLocations.armL}}/> {{localize 'REIGN.LocLeftArm'}}</label>
          <label><input type="checkbox" name="system.protectedLocations.legR" {{checked system.protectedLocations.legR}}/> {{localize 'REIGN.LocRightLeg'}}</label>
          <label><input type="checkbox" name="system.protectedLocations.legL" {{checked system.protectedLocations.legL}}/> {{localize 'REIGN.LocLeftLeg'}}</label>
        </div>
      </div>
      <div class="form-group reign-box-weapon">
        <div class="checkbox-group">
          <label>
            <input type="checkbox" name="system.equipped" {{checked system.equipped}}/> 
            <strong class="item-equipped-label">{{localize 'REIGN.Equipped'}}</strong>
          </label>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.NotesEffects'}}</label>
        <textarea name="system.notes">{{system.notes}}</textarea>
      </div>
      {{/if}}

      {{!-- SHIELD ITEM UI (Airtight RAW Update) --}}
      {{#if isShield}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.ShieldSize'}}</label>
          <select name="system.shieldSize">
            {{selectOptions shieldSizeOptions selected=system.shieldSize localize=true}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.Material'}}</label>
          <select name="system.material">
            {{selectOptions shieldMaterialOptions selected=system.material localize=true}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.ShieldArm'}}</label>
          <select name="system.shieldArm">
            {{selectOptions shieldArmOptions selected=system.shieldArm localize=true}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.ParryBonus'}} (+d)</label>
          <input type="number" name="system.parryBonus" value="{{system.parryBonus}}"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.CoverAR'}}</label>
          <input type="number" name="system.coverAR" value="{{system.coverAR}}"/>
        </div>
      </div>
      <div class="form-group reign-box-weapon">
        <div class="checkbox-group">
          <label>
            <input type="checkbox" name="system.equipped" {{checked system.equipped}}/> 
            <strong class="item-equipped-label">{{localize 'REIGN.Equipped'}}</strong>
          </label>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.NotesEffects'}}</label>
        <textarea name="system.notes">{{system.notes}}</textarea>
      </div>
      {{/if}}

      {{!-- SPELL ITEM UI --}}
      {{#if isSpell}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.Intensity'}}</label>
          <input type="number" name="system.intensity" value="{{system.intensity}}" min="1" max="10"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.CastingTime'}}</label>
          <input type="number" name="system.castingTime" value="{{system.castingTime}}" min="0"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.CastingStat'}}</label>
          <select name="system.castingStat">
            {{selectOptions attributeOptions selected=system.castingStat localize=true}}
          </select>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.SpellPool'}}</label>
          <input type="text" name="system.pool" value="{{system.pool}}" placeholder="{{localize 'REIGN.SpellPoolPlaceholder'}}"/>
        </div>
        <div class="form-group cm-col-span-2">
          <label>{{localize 'REIGN.SpellDamageLabel'}}</label>
          <input type="text" name="system.damage" value="{{system.damage}}" placeholder="{{localize 'REIGN.SpellDamagePlaceholderHint'}}"/>
        </div>
        <div class="form-group cm-col-span-2">
          <label>{{localize 'REIGN.Page'}}</label>
          <input type="text" name="system.page" value="{{system.page}}"/>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.Effect'}}</label>
        <textarea name="system.effect">{{system.effect}}</textarea>
      </div>
      {{/if}}

      {{!-- MARTIAL TECHNIQUE ITEM UI --}}
      {{#if isTechnique}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.Path'}}</label>
          <input type="text" name="system.path" value="{{system.path}}" placeholder="{{localize 'REIGN.TechniquePathPlaceholder'}}"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.Rank'}}</label>
          <input type="number" name="system.rank" value="{{system.rank}}" min="1" max="5"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.DicePool'}}</label>
          <input type="text" name="system.pool" value="{{system.pool}}" placeholder="{{localize 'REIGN.TechniquePoolPlaceholder'}}"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.Page'}}</label>
          <input type="text" name="system.page" value="{{system.page}}"/>
        </div>
      </div>
      <div class="form-group reign-box-weapon">
        <div class="checkbox-group">
          <label>
            <input type="checkbox" name="system.isPassive" {{checked system.isPassive}}/> 
            <strong class="item-equipped-label">{{localize 'REIGN.PassiveStance'}}</strong>
          </label>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.Effect'}}</label>
        <textarea name="system.effect">{{system.effect}}</textarea>
      </div>
      {{/if}}

      {{!-- ESOTERIC DISCIPLINE ITEM UI --}}
      {{#if isDiscipline}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.Path'}}</label>
          <input type="text" name="system.path" value="{{system.path}}" placeholder="{{localize 'REIGN.DisciplinePathPlaceholder'}}"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.Rank'}}</label>
          <input type="number" name="system.rank" value="{{system.rank}}" min="1" max="5"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.DicePool'}}</label>
          <input type="text" name="system.pool" value="{{system.pool}}" placeholder="{{localize 'REIGN.DisciplinePoolPlaceholder'}}"/>
        </div>
        <div class="form-group">
          <label>{{localize 'REIGN.Page'}}</label>
          <input type="text" name="system.page" value="{{system.page}}"/>
        </div>
      </div>
      <div class="form-group reign-box-weapon">
        <div class="checkbox-group">
          <label>
            <input type="checkbox" name="system.isPassive" {{checked system.isPassive}}/> 
            <strong class="item-equipped-label">{{localize 'REIGN.PassiveStance'}}</strong>
          </label>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.Effect'}}</label>
        <textarea name="system.effect">{{system.effect}}</textarea>
      </div>
      {{/if}}

      {{!-- GENERAL GEAR ITEM UI --}}
      {{#if isGear}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.Qty'}}</label>
          <input type="number" name="system.quantity" value="{{system.quantity}}"/>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.NotesEffects'}}</label>
        <textarea name="system.notes">{{system.notes}}</textarea>
      </div>
      {{/if}}

      {{!-- ADVANTAGE ITEM UI --}}
      {{#if isAdvantage}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.CostXP'}}</label>
          <input type="number" name="system.cost" value="{{system.cost}}" min="0"/>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.Effect'}}</label>
        <textarea name="system.effect">{{system.effect}}</textarea>
      </div>
      {{/if}}

      {{!-- PROBLEM ITEM UI --}}
      {{#if isProblem}}
      <div class="form-group-grid">
        <div class="form-group">
          <label>{{localize 'REIGN.BonusXP'}}</label>
          <input type="number" name="system.bonus" value="{{system.bonus}}" min="0"/>
        </div>
      </div>
      <div class="form-group-stacked">
        <label>{{localize 'REIGN.Effect'}}</label>
        <textarea name="system.effect">{{system.effect}}</textarea>
      </div>
      {{/if}}

      {{!-- NEW: COMPANY ASSET ITEM UI --}}
      {{#if isAsset}}
      <div class="reign-box-weapon">
        <span class="reign-box-weapon-title">Company Asset Details</span>
        <div class="form-group reign-checkbox-row">
            <label class="reign-bold">XP Cost:</label>
            <input type="number" name="system.cost" value="{{system.cost}}" class="reign-weapon-ap" title="RAW: Assets typically cost 10 XP" />
        </div>
      </div>
      <div class="form-group-stacked">
        <label>Description & Requirements</label>
        <textarea name="system.description">{{system.description}}</textarea>
      </div>
      {{/if}}
      
    </div>

    {{!-- ========================================== --}}
    {{!-- ACTIVE EFFECTS TAB --}}
    {{!-- ========================================== --}}
    <div class="tab {{tabs.effects}}" data-tab="effects" style="{{#unless tabs.effects}}display: none;{{/unless}}">
      <div class="reign-effects-container">
        <h3 class="item-effects-header" style="margin-top: 0;">
          <span>{{localize 'REIGN.ActiveEffects'}}</span>
          <a data-action="createEffect" title="{{localize 'REIGN.CreateEffect'}}" class="item-effects-add-btn">
            <i class="fas fa-plus"></i> {{localize 'REIGN.Add'}}
          </a>
        </h3>
        
        <p style="font-size: 0.85em; font-style: italic; color: #666; margin-bottom: 10px;">
          Effects listed here will automatically apply to the character when this item is placed in their inventory (or Equipped, if applicable).
        </p>
        
        {{#if effects.length}}
          <div class="cm-flex-col cm-gap5">
            {{#each effects as |effect|}}
              <div class="effect-item item-effect-row" data-effect-id="{{effect.id}}">
                <div class="item-effect-info {{#if effect.disabled}}item-effect-disabled{{/if}}">
                  <img src="{{effect.img}}" class="item-effect-icon"/>
                  <span class="item-effect-name">{{effect.name}}</span>
                </div>
                <div class="effect-controls item-effect-controls">
                  <a data-action="toggleEffect" title="{{localize 'REIGN.ToggleActive'}}" class="item-control-btn"><i class="fas {{#if effect.disabled}}fa-check{{else}}fa-times{{/if}}"></i></a>
                  <a data-action="editEffect" title="Quick Builder" class="item-control-btn"><i class="fas fa-edit"></i></a>
                  <a data-action="advancedEditEffect" title="Advanced Editor" class="item-control-btn"><i class="fas fa-cogs"></i></a>
                  <a data-action="deleteEffect" title="{{localize 'REIGN.DeleteEffect'}}" class="item-control-btn-delete"><i class="fas fa-trash"></i></a>
                </div>
              </div>
            {{/each}}
          </div>
        {{else}}
          <p class="item-effects-empty" style="text-align: center; padding: 20px; border: 1px dashed #ccc;">No Active Effects currently attached.</p>
        {{/if}}
      </div>
    </div>

  </section>
</div>