<div class="reign-dialog-pool-preview">
  Expected Pool: <span id="pool-value" class="reign-pool-value">...</span>
  
  {{#if hasPledges}}
  <div class="reign-dialog-warchest">
     <i class="fas fa-handshake"></i> War Chest Active: 
     {{#if pledges.bonus}}<strong>+{{pledges.bonus}}d</strong> {{/if}}
     {{#if pledges.ed}}<strong>+{{pledges.ed}} ED</strong> {{/if}}
     {{#if pledges.md}}<strong>+{{pledges.md}} MD</strong>{{/if}}
     <br><span class="reign-text-muted">(These will be consumed upon rolling)</span>
  </div>
  {{/if}}
</div>

<form class="reign-dialog-form">
  <div class="form-group reign-mb-medium reign-dialog-section">
    <label class="reign-text-danger reign-text-bold">Action Catalog:</label>
    <select name="preset" id="reign-action-preset">
      {{selectOptions presetOptions}}
    </select>
  </div>
  
  <div class="dialog-grid dialog-grid-2">
    <div class="form-group">
      <label>Primary Quality:</label>
      <div class="reign-checkbox-row">
        <select name="q1" id="reign-q1" class="reign-flex-2">
          {{selectOptions qualityOptions selected=key1}}
        </select>
        <input type="number" name="q1Limit" id="reign-q1-limit" placeholder="Max" title="Allocate Dice (Subdividing the Pot)" class="reign-flex-1" min="1"/>
      </div>
    </div>
    <div class="form-group">
      <label>Secondary Quality:</label>
      <div class="reign-checkbox-row">
        <select name="q2" id="reign-q2" class="reign-flex-2">
          {{selectOptions qualityOptionsWithNone selected="none"}}
        </select>
        <input type="number" name="q2Limit" id="reign-q2-limit" placeholder="Max" title="Allocate Dice (Subdividing the Pot)" class="reign-flex-1" min="1"/>
      </div>
    </div>
  </div>
  
  <div class="dialog-grid dialog-grid-2 reign-mt10">
    <div class="form-group"><label>Difficulty (Min Height):</label><input type="number" name="difficulty" id="reign-diff" value="0" min="0" max="10"/></div>
    <div class="form-group"><label>Mod Dice (+d):</label><input type="number" name="mod" value="0"/></div>
  </div>
  
  <div class="dialog-grid dialog-grid-2 reign-dialog-section">
    <div class="form-group">
      <label class="reign-text-warning" title="Uncheck to bypass RAW degradation (e.g. via Esoterica)">Action Economy Fatigue:</label>
      <div class="reign-checkbox-group">
        <label class="reign-checkbox-row">
          <input type="checkbox" name="erodeQ1" checked/>
          <span id="label-erode-q1">Erode: Q1</span>
        </label>
        <label class="reign-checkbox-row">
          <input type="checkbox" name="erodeQ2" checked/>
          <span id="label-erode-q2">Erode: Q2</span>
        </label>
      </div>
    </div>
    
    <div class="form-group reign-flex-col reign-flex-gap12">
      <div>
        <label class="reign-text-danger reign-text-bold">Target Enemy Company:</label>
        <select name="targetCompany" id="reign-target-company">
          <option value="none">-- None --</option>
          {{#each targetCompanies}}
            <option value="{{this.id}}">{{this.name}}</option>
          {{/each}}
        </select>
      </div>
      
      <div>
        <label>Target Quality (To Damage):</label>
        <select name="targetQuality" id="reign-target">
          {{selectOptions qualityOptionsWithNone selected="none"}}
        </select>
      </div>
    </div>
  </div>
</form>